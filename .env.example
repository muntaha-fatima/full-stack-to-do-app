# Database Configuration
POSTGRES_USER=todoapp
POSTGRES_PASSWORD=todoapp_dev_password
POSTGRES_DB=todoapp
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://todoapp:todoapp_dev_password@localhost:5432/todoapp

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Backend Configuration
BACKEND_PORT=8000
SECRET_KEY=dev_secret_key_change_in_production_min_32_chars
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_IP=1000

# Logging
LOG_LEVEL=INFO

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@todoapp.com
FROM_NAME=Todo App

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email Settings
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1
