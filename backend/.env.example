# Environment
ENVIRONMENT=development

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - JSON array of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:8000","http://0.0.0.0:3000","http://0.0.0.0:3001","http://0.0.0.0:8000","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:8000","http://localhost:8001"]

# Trusted hosts (for production) - JSON array
ALLOWED_HOSTS=["*"]

# Database - Neon PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host/database?ssl=require
# IMPORTANT: asyncpg requires 'postgresql+asyncpg://' protocol and 'ssl=require' (not 'sslmode')
DATABASE_URL=postgresql+asyncpg://neondb_owner:npg_7zrO6HsdWvDS@ep-steep-mouse-a47f4i2v-pooler.us-east-1.aws.neon.tech/neondb?ssl=require

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_IP=1000

# Logging
LOG_LEVEL=INFO

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# SMTP Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@todoapp.com
FROM_NAME=Todo App

# Celery Configuration (optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email Settings (optional)
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1

# Cohere Configuration
COHERE_API_KEY=your-cohere-api-key-here
